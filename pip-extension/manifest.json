{
  "manifest_version": 3,
  "name": "Under Pulse PiP",
  "version": "1.0",
  "description": "Selecione qualquer elemento da página e exiba em Picture-in-Picture flutuante",
  "permissions": ["activeTab", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Under Pulse PiP"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }]
}
